# Butterfly Radio - AI 配置

# ─── LLM（大语言模型）───
DEEPSEEK_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-v4-flash

# ─── TTS（语音合成）───
# 可选: edge（免费）, volcengine（火山引擎）, chat_tts（本地）
TTS_PROVIDER=edge

# Edge TTS 音色（免费，无需 API Key）
# 可选: xiaoxiao(活泼女声), xiaoyi(温柔女声), yunxi(年轻男声), yunyang(播音男声), xiaomeng(可爱女声), xiaochen(知性女声)
TTS_VOICE=xiaoxiao

# 火山引擎 TTS（需要在 console.volcengine.com 开通）
# VOLC_TTS_APPID=your-appid
# VOLC_TTS_TOKEN=your-token
